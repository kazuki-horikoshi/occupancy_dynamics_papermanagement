@article{beck_high-resolution_2023,
	title = {High-resolution (1 km) {Köppen}-{Geiger} maps for 1901–2099 based on constrained {CMIP6} projections},
	volume = {10},
	issn = {2052-4463},
	url = {https://www.nature.com/articles/s41597-023-02549-6},
	doi = {10.1038/s41597-023-02549-6},
	abstract = {Abstract
            
              We introduce Version 2 of our widely used 1-km Köppen-Geiger climate classification maps for historical and future climate conditions. The historical maps (encompassing 1901–1930, 1931–1960, 1961–1990, and 1991–2020) are based on high-resolution, observation-based climatologies, while the future maps (encompassing 2041–2070 and 2071–2099) are based on downscaled and bias-corrected climate projections for seven shared socio-economic pathways (SSPs). We evaluated 67 climate models from the Coupled Model Intercomparison Project phase 6 (CMIP6) and kept a subset of 42 with the most plausible CO
              2
              -induced warming rates. We estimate that from 1901–1930 to 1991–2020, approximately 5\% of the global land surface (excluding Antarctica) transitioned to a different major Köppen-Geiger class. Furthermore, we project that from 1991–2020 to 2071–2099, 5\% of the land surface will transition to a different major class under the low-emissions SSP1-2.6 scenario, 8\% under the middle-of-the-road SSP2-4.5 scenario, and 13\% under the high-emissions SSP5-8.5 scenario. The Köppen-Geiger maps, along with associated confidence estimates, underlying monthly air temperature and precipitation data, and sensitivity metrics for the CMIP6 models, can be accessed at
              www.gloh2o.org/koppen
              .},
	language = {en},
	number = {1},
	urldate = {2025-06-12},
	journal = {Scientific Data},
	author = {Beck, Hylke E. and McVicar, Tim R. and Vergopolan, Noemi and Berg, Alexis and Lutsko, Nicholas J. and Dufour, Ambroise and Zeng, Zhenzhong and Jiang, Xin and Van Dijk, Albert I. J. M. and Miralles, Diego G.},
	month = oct,
	year = {2023},
	pages = {724},
}

@article{mihara_thermal_2025,
	title = {Thermal {Comfort} {Beyond} {Expectations}: {Insights} from {Home} and {Office} {Environments} in {Two} {Climatic} {Regions}},
	abstract = {This study quantitatively analyzed thermally comfortable ranges based on a long-term field survey conducted in home and office environments in Singapore and Tokyo, Japan and discussed factors influencing thermal comfort at different locations and seasons. By applying a Bayesian estimation, we revealed the probability of comfortable temperature range at homes was to up to 4.2 times wider than in offices. We suspected people may feel they have higher control to their perceived environment at homes than in offices which resulted in lower thermal expectations under relatively higher and lower temperature thresholds. Particularly, in Japan, the ranges in spring and autumn were up to 1.6 times wider than in summer. Interestingly, in Singapore, the comfortable temperature range in naturally ventilated offices was 1.4 times wider than in air-conditioned offices, likely due to thermal adaptation. Our findings suggest that subject’s thermal expectation could be a critical component when justifying comfortable temperature range, which is particularly important for adjusting temperature setting in air conditioning system in practice.},
	language = {en},
	author = {Mihara, Kuniaki and Arisaka, Sohei and Ono, Eikichi and Cheung, Toby},
	year = {2025},
}

@article{mihara_thermal_2024,
	title = {Thermal {Comfort} and {Self}-reported {Productivity} at {Home} and {Office}: a longitudinal field study},
	abstract = {This study aims to verify participants' thermal comfort and self-reported productivity when working from their home or office in Singapore (hot season) and Tokyo, Japan (cold season). Through a longitudinal field study, over the period from January to April 2023, twenty-four participants completed surveys daily. We monitored the indoor environment parameters in the participant’s homes and offices and gathered user feedback using a watch-based micro-survey. Compared to the office settings, we found warmer air temperatures of 4.6 ºC at homes in Singapore and cooler temperature of 3.1 ºC at homes in Japan, without compromising selfreported thermal comfort and productivity. Meanwhile, we observed a narrower comfortable temperature range in the offices compared to homes. Our findings suggested participants prefer various indoor temperature ranges under different locations and seasons. This suggests the possibility to enhance the participants’ thermal comfort by aligning their thermal expectations, e.g., creating a home-like office setting, which would reduce the energy needed for space conditioning.},
	language = {en},
	author = {Mihara, Kuniaki and Cheung, Toby and Ono, Eikichi and Tartarini, Federico and Hasama, Takamasa},
	year = {2024},
}

