@article{peng_case_2016,
	title = {Case {Study} {Review}: {Prediction} {Techniques} in {Intelligent} {HVAC} {Control} {Systems}},
	copyright = {http://rightsstatements.org/page/InC-NC/1.0/, info:eu-repo/semantics/openAccess},
	shorttitle = {Case {Study} {Review}},
