@article{mataloto_3d_2021,
	title = {{3D} {IoT} {System} for {Environmental} and {Energy} {Consumption} {Monitoring} {System}},
	volume = {13},
	issn = {2071-1050},
	url = {https://www.mdpi.com/2071-1050/13/3/1495},
	doi = {10.3390/su13031495},
	abstract = {Energy consumption in buildings depends on the local climate, building characteristics, and user behavior. Focusing on user interaction, this research work developed a novel approach to monitoring and interaction with local users by providing in situ context information through graphic descriptions of energy consumption and indoor/outdoor environment parameters: temperature, luminosity, and humidity, which are routinely measured in real-time and stored to identify consumption patterns and other savings actions. To involve local users, collected data are represented in 3D color representation using building 3d models. A simpliﬁed color scale depicts environmental comfort (low/comfortable/high temperature/relative humidity) and energy consumption (above/below usual patterns). We found that these indices induced user commitment and increased their engagement and participation in saving actions like turning off lights and better management of air conditioning systems.},
	language = {en},
	number = {3},
