@misc{lyu_llm-powered_2026,
	address = {Rochester, NY},
	type = {{SSRN} {Scholarly} {Paper}},
	title = {{LLM}-{Powered} {Agent} for {Occupant}-{Centric} {Indoor} {Environment} {Control}: {Design}, {Implementation}, and {Evaluation}},
	shorttitle = {{LLM}-{Powered} {Agent} for {Occupant}-{Centric} {Indoor} {Environment} {Control}},
	url = {https://papers.ssrn.com/abstract=6136668},
	doi = {10.2139/ssrn.6136668},
	abstract = {Buildings account for nearly 30\% of global final energy consumption, with HVAC-driven cooling loads growing at 4\% annually. Conventional rule-based environment control strategies often struggle with multi-device coordination and individualized comfort requests. This study develops a large language model (LLM)-based occupant-centric control system that integrates multi-source sensing, including environmental parameters, skin temperature, natural language input, together with a knowledge graph for personalized reasoning. Guided by prompt engineering, the LLM agent generates structured control objectives that are translated into executable commands and dispatched to IoT-enabled devices, enabling dynamic multi-device coordination. An evaluation framework was developed to assess system performance from both objective and subjective perspectives. Results show that this system exhibits good responsiveness, stability, and consistency across experimental trials. Expert review rated device selection and setpoint correctness at 8.0±1.3/10 and 7.9±1.3/10, respectively. A field deployment involving 10 subjects further demonstrated favorable comfort and acceptability. Compared with manual control, the LLM-based strategy reduced electricity consumption by an average of 20.4\% without compromising comfort. These findings highlight the potential of LLM-based environment control for adaptive, personalized, and energyefficient indoor environmental management.},
	language = {en},
	urldate = {2026-02-26},
	publisher = {Social Science Research Network},
	author = {Lyu, Junmeng and Lai, Dayi and Zhang, Hui and Lian, Zhiwei},
	month = jan,
	year = {2026},
	keywords = {Air conditioning, Indoor environment, Large Language Model, Occupant centric control, Thermal comfort, Thermal imaging},
}

