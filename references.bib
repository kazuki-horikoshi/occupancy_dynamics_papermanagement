	publisher = {American Society of Civil Engineers},
	author = {Nepal, M. P. and Zhang, J. and Webster, A. and Staub-French, S. and Pottinger, R. and Lawrence, M.},
	month = apr,
	year = {2009},
	pages = {506--515},
}

@inproceedings{jiang_easympc_2025,
	title = {{EasyMPC}: {An} {Open}-{Source} {Toolkit} for {Model} {Predictive} {Control} in {Smart} {Buildings}},
	isbn = {978-1-964173-09-2},
	shorttitle = {{EasyMPC}},
	url = {https://store.accuristech.com/standards/or-25-c157-easympc-an-open-source-toolkit-for-model-predictive-control-in-smart-buildings?product_id=3017435},
	doi = {10.63044/w25jia157},
	abstract = {Model predictive control (MPC) plays a vital role in providing a comfortable indoor environment for occupants, reducing carbon emissions to meet carbon neutrality, and offering flexibility towards future power grids. However, the real-world implementation of MPC is limited by challenges associated with large-scale control-oriented building dynamic modeling and accurate disturbance predictions, including solar radiation, ambient temperature, and occupancy. To address these challenges and facilitate largescale real-world MPC deployment aligned with the Net Zero Emissions by 2050, we have developed and open-sourced a toolkit for MPC in smart building control. This toolkit includes a modularized neural network incorporating physical priors for control-oriented building dynamic modeling and a BayesianCNN-LSTM (BC-LSTM) model for forecasting solar radiation, ambient temperature, and occupancy. The proposed data-driven approach allows for direct MPC implementation without extensive modeling efforts. This study contributes to advancing building control technologies, improving energy efficiency, and enhancing grid flexibility.},
	language = {en},
	urldate = {2025-11-22},
	booktitle = {2025 {ASHRAE} {Winter} {Conference}},
	publisher = {ASHRAE},
	author = {Jiang, Zixin and Dong, Bing},
	month = may,
	year = {2025},
}

